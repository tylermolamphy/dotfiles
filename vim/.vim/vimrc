execute pathogen#infect()
set nocompatible
filetype plugin on
syntax on
set tabstop=2
set softtabstop=0 noexpandtab
set shiftwidth=4
set mouse=a
map q :q!<cr>
let g:vimwiki_list = [{'path':'~/Dropbox/vimwiki', 'ext':'.md', 'diary_sort':'asc'}]
map <Leader>wc :! ~/dotfiles/vim/scripts/cleanwiki.sh<cr>
map <Leader>t :r! date +"\%Y-\%m-\%d \%H:\%M:\%S"<cr>o
map <Leader>\ :NERDTreeToggle<cr>
map <Leader>db :g/^$/d<cr>
au FileType markdown vmap <Leader>ta :EasyAlign*<Bar><Enter>
